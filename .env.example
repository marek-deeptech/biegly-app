# Skopiuj do .env.local i uzupełnij (NIE commituj .env.local).
# Projekt Supabase MUSI być w regionie UE (poufność akt).

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
# service_role tylko po stronie serwera / funkcji Pythona — NIGDY w kliencie:
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
